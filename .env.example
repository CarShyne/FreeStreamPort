# FreeStream environment variables
# Copy to .env and adjust for your deployment

PORT=3000
MEDIA_FOLDER=/media/movies
TV_FOLDER=/media/tvshows
TMDB_API_KEY=your_tmdb_api_key_here

# --- Single user (simple) ---
FREESTREAM_USER=admin
FREESTREAM_PASSWORD=admin

# --- Multiple users (pick one method) ---
# JSON in env (quote the whole value in Docker/Portainer):
# FREESTREAM_USERS={"admin":"pass1","family":"pass2"}
#
# Or mount a JSON file (best for @ and special characters):
# FREESTREAM_USERS_FILE=/app/server/users.json

# Session storage (persist logins across restarts — mount this volume in Docker)
# FREESTREAM_DATA_DIR=/data

# Session length: 7 days default, 90 days when "Keep me signed in" is checked
# FREESTREAM_SESSION_DAYS=7
# FREESTREAM_REMEMBER_DAYS=90

# Legacy file-based single user
# FREESTREAM_USER_FILE=/run/secrets/freestream_user
# FREESTREAM_PASSWORD_FILE=/run/secrets/freestream_password
